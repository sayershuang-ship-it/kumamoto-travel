---
import Base from '../layouts/Base.astro';
import { trip } from '../data/itinerary';

const totalActual = trip.budgetSummary.reduce((s, i) => s + i.amount, 0);
const allLocationsJson = JSON.stringify(trip.locations);
---

<Base title="熊本四天三夜自由行">
  <header class="hero">
    <h1>🗾 {trip.title}</h1>
    <p class="subtitle">{trip.subtitle}</p>
    <div class="meta">
      <span>📅 {trip.dates}</span>
      <span>👥 {trip.travelers}人</span>
      <span>💰 ¥{trip.budget.toLocaleString()} 預算</span>
    </div>
  </header>

  <nav class="nav">
    <a href="/" class="active">📋 總覽</a>
    <a href="/day1">Day 1</a>
    <a href="/day2">Day 2</a>
    <a href="/day3">Day 3</a>
    <a href="/day4">Day 4</a>
    <a href="/map">🗺️ 地圖</a>
    <a href="/weather">🌤️ 天氣</a>
    <a href="/tickets">🎫 預訂</a>
  </nav>

  <main class="container" style="padding-top: 1.5rem;">
    <!-- PWA Install Banner -->
    <div class="pwa-banner" id="pwa-install">
      📱 安裝到主畫面，離線也能看行程
      <br /><button id="install-btn">安裝 App</button>
    </div>

    <!-- Weather -->
    <div class="weather-banner">
      <div class="icon">🌤️</div>
      <div>
        <strong>{trip.weather.condition}</strong><br />
        {trip.weather.temp} · {trip.weather.tip}
      </div>
    </div>

    <!-- Quick Stats -->
    <div class="card">
      <h2 style="margin-bottom:0.75rem;">📊 快速統計</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:0.75rem;">
        <div style="background:var(--bg);border-radius:0.75rem;padding:1rem;text-align:center;">
          <div style="font-size:1.5rem;font-weight:700;">4天</div>
          <div style="font-size:0.8rem;color:var(--text-muted);">行程天數</div>
        </div>
        <div style="background:var(--bg);border-radius:0.75rem;padding:1rem;text-align:center;">
          <div style="font-size:1.5rem;font-weight:700;">11</div>
          <div style="font-size:0.8rem;color:var(--text-muted);">走訪景點</div>
        </div>
        <div style="background:var(--bg);border-radius:0.75rem;padding:1rem;text-align:center;">
          <div style="font-size:1.5rem;font-weight:700;">3回</div>
          <div style="font-size:0.8rem;color:var(--text-muted);">溫泉入浴</div>
        </div>
        <div style="background:var(--bg);border-radius:0.75rem;padding:1rem;text-align:center;">
          <div style="font-size:1.5rem;font-weight:700;">¥{totalActual.toLocaleString()}</div>
          <div style="font-size:0.8rem;color:var(--text-muted);">預估總花費</div>
        </div>
      </div>
    </div>

    <!-- Budget Overview -->
    <div class="card">
      <h2 style="margin-bottom:0.75rem;">💰 預算分配</h2>
      <div style="display:flex;flex-wrap:wrap;gap:0.25rem;margin-bottom:1rem;">
        {trip.budgetSummary.map(i => (
          <span class="tag tag-{i.label === '住宿' ? 'hotel' : i.label === '餐飲' ? 'food' : i.label === '交通' ? 'transport' : i.label === '門票' ? 'ticket' : i.label === '溫泉' ? 'onsen' : 'shopping'}">{i.icon} {i.label}</span>
        ))}
      </div>
      <table class="budget-table">
        <thead><tr><th>項目</th><th>金額</th><th>備註</th></tr></thead>
        <tbody>
          {trip.budgetSummary.map(i => (
            <tr><td>{i.icon} {i.label}</td><td><strong>¥{i.amount.toLocaleString()}</strong></td><td style="color:var(--text-muted);font-size:0.85rem;">{i.note}</td></tr>
          ))}
          <tr class="total-row"><td>總計</td><td><strong>¥{totalActual.toLocaleString()}</strong></td><td style="color:var(--accent-green);font-size:0.85rem;">✅ 預算內</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Daily Summary -->
    <h2 style="margin:1.5rem 0 1rem;">📋 每日行程</h2>
    {trip.days.map(day => (
      <a href={`/day${day.day}`} style="text-decoration:none;color:inherit;">
        <div class="card" style="cursor:pointer;transition:transform 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
          <div class="day-header">
            <div class="day-num">{day.day}</div>
            <div>
              <div style="font-size:0.85rem;color:var(--text-muted);">{day.date}</div>
              <div class="day-title">{day.title}</div>
              <div class="day-subtitle">{day.subtitle}</div>
            </div>
            <div style="margin-left:auto;text-align:right;">
              <div style="font-weight:700;color:var(--brand);">¥{day.dayBudget.toLocaleString()}</div>
              <div style="font-size:0.75rem;color:var(--text-muted);">{day.activities.length} 個活動</div>
            </div>
          </div>
          <div style="display:flex;gap:0.25rem;flex-wrap:wrap;">
            {day.activities.map(a => (
              <span class="tag tag-{a.type}">{a.icon} {a.title.slice(0,8)}</span>
            ))}
          </div>
        </div>
      </a>
    ))}

    <!-- Map Preview -->
    <div class="card" style="margin-top:1rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
        <h2>🗺️ 熊本全境地圖</h2>
        <a href="/map" style="font-size:0.85rem;color:var(--brand);text-decoration:none;font-weight:600;">展開 ↗</a>
      </div>
      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
      <div id="index-map" style="width:100%;height:360px;border-radius:0.75rem;"></div>
    </div>
  </main>

  <footer class="footer">
    <p>Powered by Travel Planner Skill · Astro + Cloudflare Pages</p>
    <p style="font-size:0.75rem;">地圖資料 © <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener" style="color:var(--brand);">OpenStreetMap</a> contributors</p>
  </footer>
</Base>

<script define:vars={{ allLocationsJson }}>
  const locations = JSON.parse(allLocationsJson);
  const script = document.createElement('script');
  script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  script.onload = () => {
    const L = window.L;
    const map = L.map('index-map').setView([32.8031, 130.7079], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors',
      maxZoom: 19,
    }).addTo(map);
    locations.forEach(loc => {
      L.circleMarker([loc.lat, loc.lng], {
        radius: 8, fillColor: '#d4342c', color: '#fff', weight: 2, fillOpacity: 0.9,
      }).addTo(map).bindPopup(`<strong>${loc.name}</strong>`);
    });
  };
  document.head.appendChild(script);
</script>
