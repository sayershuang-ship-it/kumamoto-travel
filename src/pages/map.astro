---
import Base from '../layouts/Base.astro';
import { trip } from '../data/itinerary';
const focusDay = Astro.url.searchParams.get('day');
const locationsJson = JSON.stringify(trip.locations);
const routesJson = JSON.stringify(trip.dailyRoutes);
const focusDayStr = focusDay ?? 'null';
const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY ?? '';
---

<Base title="景點地圖 | 熊本旅行">

  <header class="hero" style="padding:2rem 1rem;">
    <a href="/" style="color:white;opacity:0.7;text-decoration:none;font-size:0.85rem;">← 回總覽</a>
    <h1 style="margin-top:0.5rem;">🗺️ 熊本全境地圖</h1>
    <p class="subtitle">OpenStreetMap · 全景點標記 + 每日路線</p>
  </header>

  <nav class="nav">
    <a href="/">📋 總覽</a>
    <a href="/day1">Day 1</a>
    <a href="/day2">Day 2</a>
    <a href="/day3">Day 3</a>
    <a href="/day4">Day 4</a>
    <a href="/map" class="active">🗺️ 地圖</a>
    <a href="/weather">🌤️ 天氣</a>
    <a href="/tickets">🎫 預訂</a>
    <a href="/expenses">💰 花費</a>
    <a href="/calendar">📅 日曆</a>
  </nav>

  <main class="container" style="padding-top:1.5rem;">

    <!-- Day Selector -->
    <div class="card">
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
        <a href="/map"
          style={`text-decoration:none;padding:0.5rem 1.25rem;border-radius:999px;font-weight:600;font-size:0.85rem;background:${!focusDay ? 'var(--brand)' : 'var(--bg)'};color:${!focusDay ? 'white' : 'var(--text)'};`}
        >📍 全部景點</a>
        {trip.days.map(d => (
          <a href={`/map?day=${d.day}`}
            style={`text-decoration:none;padding:0.5rem 1.25rem;border-radius:999px;font-weight:600;font-size:0.85rem;background:${focusDay === String(d.day) ? 'var(--brand)' : 'var(--bg)'};color:${focusDay === String(d.day) ? 'white' : 'var(--text)'};`}
          >Day {d.day} · {d.title}</a>
        ))}
      </div>

      {focusDay && (
        <div style="margin-top:1rem;padding:0.75rem;background:var(--bg);border-radius:0.75rem;font-size:0.85rem;">
          <strong>Day {focusDay} 路線：</strong>
          {trip.days[Number(focusDay)-1]?.activities.map((a, i, arr) => (
            <span>{a.icon} <strong>{a.title}</strong>{i < arr.length - 1 ? ' → ' : ''}</span>
          ))}
        </div>
      )}
    </div>

    <!-- Leaflet Map -->
    <div class="card" style="padding:0;overflow:hidden;">
      <div id="leaflet-map" style="width:100%;height:480px;border-radius:1rem;"></div>
    </div>

    <!-- Google Maps Directions Links -->
    <div class="card">
      <h2 style="margin-bottom:0.75rem;">🚗 Google Maps 路線查詢</h2>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        {trip.days.map(d => {
          const stops = d.activities.filter(a => a.type !== 'hotel' && a.type !== 'free').slice(0, 4);
          const gmUrl = `https://www.google.com/maps/dir/${stops.map(a => encodeURIComponent(a.title + ' 熊本')).join('/')}`;
          return (
            <div style="background:var(--bg);border-radius:0.75rem;padding:0.75rem;">
              <strong style="font-size:0.85rem;">Day {d.day}: {d.title}</strong>
              <div style="display:flex;gap:0.5rem;margin-top:0.5rem;flex-wrap:wrap;align-items:center;">
                {stops.map((a, i) => (
                  <span style="font-size:0.8rem;">{a.icon} {a.title}{i < stops.length - 1 ? ' →' : ''}</span>
                ))}
                <a href={gmUrl} target="_blank" rel="noopener noreferrer"
                  style="font-size:0.8rem;color:var(--brand);text-decoration:none;font-weight:600;margin-left:auto;">
                  ↗ Google Maps
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Location List -->
    <div class="card">
      <h2 style="margin-bottom:0.75rem;">📍 景點列表</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.5rem;">
        {trip.locations.map(loc => (
          <div style="background:var(--bg);border-radius:0.75rem;padding:0.75rem;font-size:0.85rem;">
            <strong>{loc.name}</strong><br />
            <span style="color:var(--text-muted);font-size:0.75rem;">{loc.lat.toFixed(4)}, {loc.lng.toFixed(4)}</span>
          </div>
        ))}
      </div>
    </div>

  </main>

  <footer class="footer">
    <a href="/" style="color:var(--brand);">← 回總覽</a>
  </footer>
</Base>

<script define:vars={{ locationsJson, routesJson, focusDayStr, googleMapsApiKey }}>
  const locations = JSON.parse(locationsJson);
  const dailyRoutes = JSON.parse(routesJson);
  const focusDay = focusDayStr !== 'null' ? Number(focusDayStr) : null;

  const DAY_COLORS = { 1: '#d4342c', 2: '#2563eb', 3: '#16a34a', 4: '#9333ea' };

  window.initMap = function initMap() {
    const map = new google.maps.Map(document.getElementById('leaflet-map'), {
      center: { lat: 32.8031, lng: 130.7079 },
      zoom: 13,
    });

    // Add markers
    locations.forEach(loc => {
      const marker = new google.maps.Marker({
        position: { lat: loc.lat, lng: loc.lng },
        map,
        title: loc.name,
      });
      const infoWindow = new google.maps.InfoWindow({ content: `<strong>${loc.name}</strong>` });
      marker.addListener('click', () => infoWindow.open(map, marker));
    });

    // Draw routes
    const routesToDraw = focusDay
      ? { [focusDay]: dailyRoutes[focusDay] }
      : dailyRoutes;

    const bounds = new google.maps.LatLngBounds();
    let hasRoute = false;

    Object.entries(routesToDraw).forEach(([day, coords]) => {
      if (!coords || coords.length < 2) return;
      const color = DAY_COLORS[Number(day)] || '#6b7280';
      const path = coords.map(([lat, lng]) => ({ lat, lng }));

      new google.maps.Polyline({
        path,
        map,
        strokeColor: color,
        strokeWeight: 3,
        strokeOpacity: 0.8,
      });

      // Start/end markers for the focused day
      if (focusDay) {
        new google.maps.Marker({
          position: path[0],
          map,
          label: { text: '出發', fontSize: '10px' },
          icon: { path: google.maps.SymbolPath.CIRCLE, scale: 10, fillColor: '#10b981', fillOpacity: 1, strokeColor: '#fff', strokeWeight: 2 },
        });
        new google.maps.Marker({
          position: path[path.length - 1],
          map,
          label: { text: '終點', fontSize: '10px' },
          icon: { path: google.maps.SymbolPath.CIRCLE, scale: 10, fillColor: '#6b7280', fillOpacity: 1, strokeColor: '#fff', strokeWeight: 2 },
        });
      }

      path.forEach(p => bounds.extend(p));
      hasRoute = true;
    });

    if (focusDay && hasRoute) {
      map.fitBounds(bounds, 40);
    }
  };

  const script = document.createElement('script');
  script.src = `https://maps.googleapis.com/maps/api/js?key=${googleMapsApiKey}&callback=initMap`;
  script.async = true;
  document.head.appendChild(script);
</script>
