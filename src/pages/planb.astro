---
import Base from '../layouts/Base.astro';
import { trip, contingency } from '../data/itinerary';
const tripJson = JSON.stringify(trip);

// 收集所有有替代方案的活動
const swappables = trip.days.flatMap(d =>
  d.activities.filter(a => a.alt).map(a => ({ day: d.day, date: d.date, act: a }))
);
---

<Base title="應變計畫中心">
  <header class="hero" style="padding:2rem 1rem;">
    <h1>🆘 應變計畫中心</h1>
    <p class="subtitle">下雨、太熱、延誤、走不動——都有 Plan B</p>
  </header>

  <nav class="nav">
    <a href="/">📋 總覽</a>
    <a href="/day1">Day 1</a>
    <a href="/day2">Day 2</a>
    <a href="/day3">Day 3</a>
    <a href="/day4">Day 4</a>
    <a href="/planner">🧭 規劃</a>
    <a href="/map">🗺️ 地圖</a>
    <a href="/weather">🌤️ 天氣</a>
    <a href="/tickets">🎫 預訂</a>
    <a href="/expenses">💰 花費</a>
    <a href="/calendar">📅 日曆</a>
    <a href="/import">📥 匯入</a>
    <a href="/planb" class="active">🆘 應變</a>
  </nav>

  <main class="container" style="padding-top:1.5rem;">
    <!-- Live rain alert (Open-Meteo) -->
    <div id="rain-alert" class="alert-banner" style="display:none;"></div>

    <!-- Scenarios -->
    <h2 style="margin-bottom:0.75rem;">📖 情境應變手冊</h2>
    {contingency.scenarios.map(s => (
      <details class="scenario-card" id={`scenario-${s.id}`}>
        <summary>
          <span class="s-icon">{s.icon}</span>
          <span>{s.title}<div class="s-desc">{s.desc}</div></span>
        </summary>
        <div class="s-body">
          <ul>{s.tips.map(t => <li>{t}</li>)}</ul>
        </div>
      </details>
    ))}

    <!-- One-click swaps -->
    <div class="card" style="margin-top:1.5rem;">
      <h2 style="margin-bottom:0.5rem;">🔄 雨天替代方案（一鍵套用）</h2>
      <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:1rem;">
        戶外景點 → 室內替代。套用後會更新 🧭 規劃工作台的自訂行程，可隨時還原。
      </p>
      <div id="swap-list">
        {swappables.map(s => (
          <div class="alt-row" data-title={s.act.title} data-day={s.day}>
            <span style="font-size:0.8rem;color:var(--text-muted);white-space:nowrap;">Day {s.day}</span>
            <span>{s.act.icon} <strong>{s.act.title}</strong></span>
            <span class="arrow">→</span>
            <span>{s.act.alt.icon} <strong>{s.act.alt.title}</strong>
              <span style="font-size:0.8rem;color:var(--text-muted);">（{s.act.alt.desc}）</span></span>
            <button class="btn secondary swap-btn" style="margin-left:auto;">☔ 套用</button>
          </div>
        ))}
      </div>
    </div>

    <!-- Indoor spots pool -->
    <div class="card">
      <h2 style="margin-bottom:0.75rem;">🏢 雨天備用景點庫</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:0.75rem;">
        {contingency.indoorSpots.map(p => (
          <div style="border:1px solid var(--border);border-radius:0.75rem;padding:0.85rem 1rem;">
            <div style="font-weight:700;">{p.icon} {p.name}</div>
            <div style="font-size:0.82rem;color:var(--text-muted);">{p.desc}</div>
            <div style="font-size:0.8rem;margin-top:0.25rem;">
              <span class="tag tag-ticket">{p.cost}</span>
              <span class="tag tag-free">{p.area}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Emergency quick card -->
    <div class="card" style="border-left:4px solid #ef4444;">
      <h2 style="margin-bottom:0.75rem;">🚨 緊急聯絡快速卡</h2>
      <table class="budget-table">
        <tbody>
          <tr><td>🚑 救護車 / 火警</td><td><strong style="font-size:1.1rem;">119</strong></td></tr>
          <tr><td>👮 警察</td><td><strong style="font-size:1.1rem;">110</strong></td></tr>
          <tr><td>🗣️ JNTO 24hr 外語旅客熱線（中文可）</td><td><strong>050-3816-2787</strong></td></tr>
          <tr><td>🚕 熊本計程車（TaxiGO app 可叫車）</td><td>市區起跳約 ¥670</td></tr>
          <tr><td>🏥 熊本市民病院（急診）</td><td>096-365-1711</td></tr>
        </tbody>
      </table>
      <p style="font-size:0.8rem;color:var(--text-muted);margin-top:0.5rem;">
        💡 此頁已被 PWA 快取，離線也能開。就醫記得帶護照、保留收據申請保險理賠。
      </p>
    </div>
  </main>

  <footer class="footer">
    <a href="/" style="color:var(--brand);">← 回總覽</a>
  </footer>
</Base>

<script is:inline src="/js/trip-tools.js"></script>
<script define:vars={{ tripJson }}>
  const T = window.TripTools;
  const trip = JSON.parse(tripJson);

  /* ---- 一鍵套用 / 還原替代方案 ---- */
  // alt 定義存在 base trip 裡（overlay 可能已被使用者改過，所以由 title 對回 base）
  const altByTitle = {};
  trip.days.forEach(d => d.activities.forEach(a => { if (a.alt) altByTitle[a.title] = a.alt; }));

  function findInPlan(days, title) {
    for (const d of days) {
      const i = d.activities.findIndex(a => a.title === title);
      if (i !== -1) return { d, i };
    }
    return null;
  }

  function refreshButtons() {
    const days = T.loadPlan(trip.days);
    document.querySelectorAll('.alt-row').forEach(row => {
      const origTitle = row.dataset.title;
      const alt = altByTitle[origTitle];
      const btn = row.querySelector('.swap-btn');
      const applied = findInPlan(days, alt.title);
      const original = findInPlan(days, origTitle);
      if (applied && applied.d.activities[applied.i].swapped) {
        btn.textContent = '↩️ 還原';
        btn.classList.remove('secondary');
        btn.classList.add('danger');
        btn.disabled = false;
      } else if (original) {
        btn.textContent = '☔ 套用';
        btn.classList.add('secondary');
        btn.classList.remove('danger');
        btn.disabled = false;
      } else {
        btn.textContent = '已從行程移除';
        btn.disabled = true;
      }
    });
  }

  document.getElementById('swap-list').addEventListener('click', e => {
    const btn = e.target.closest('.swap-btn');
    if (!btn || btn.disabled) return;
    const row = btn.closest('.alt-row');
    const origTitle = row.dataset.title;
    const alt = altByTitle[origTitle];
    const days = T.loadPlan(trip.days);

    const applied = findInPlan(days, alt.title);
    if (applied && applied.d.activities[applied.i].swapped) {
      // 還原
      const cur = applied.d.activities[applied.i];
      applied.d.activities[applied.i] = cur._orig;
    } else {
      const found = findInPlan(days, origTitle);
      if (!found) return;
      const cur = found.d.activities[found.i];
      found.d.activities[found.i] = {
        ...cur,
        icon: alt.icon, title: alt.title, desc: alt.desc,
        budget: alt.budget, type: alt.type,
        swapped: true,
        _orig: { ...cur },
      };
    }
    T.savePlan(days);
    refreshButtons();
  });

  refreshButtons();

  /* ---- 行程期間降雨機率（Open-Meteo，免金鑰） ---- */
  (async () => {
    try {
      const end = new Date(trip.startDate + 'T00:00:00');
      end.setDate(end.getDate() + trip.days.length - 1);
      const endStr = end.toISOString().slice(0, 10);
      const url = `https://api.open-meteo.com/v1/forecast?latitude=32.80&longitude=130.71&daily=precipitation_probability_max,temperature_2m_max&timezone=Asia%2FTokyo&start_date=${trip.startDate}&end_date=${endStr}`;
      const res = await fetch(url);
      const data = await res.json();
      const probs = data?.daily?.precipitation_probability_max;
      const temps = data?.daily?.temperature_2m_max;
      if (!probs) return;
      const rainy = [], hot = [];
      probs.forEach((p, i) => { if (p >= 50) rainy.push(`Day ${i + 1} (${p}%)`); });
      (temps || []).forEach((t, i) => { if (t >= 34) hot.push(`Day ${i + 1} (${Math.round(t)}°C)`); });
      if (rainy.length || hot.length) {
        const el = document.getElementById('rain-alert');
        const parts = [];
        if (rainy.length) parts.push(`☔ 高降雨機率：${rainy.join('、')} — 建議先看「午後雷陣雨」情境並套用替代方案`);
        if (hot.length) parts.push(`🥵 高溫警戒：${hot.join('、')} — 中午避開戶外`);
        el.innerHTML = parts.join('<br/>');
        el.style.display = 'block';
        if (rainy.length) document.getElementById('scenario-rain').open = true;
        else if (hot.length) document.getElementById('scenario-heat').open = true;
      }
    } catch { /* 離線時略過即時預報 */ }
  })();
</script>
